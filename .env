# =============================================================
# RoC Desk — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in the values.
#   cp .env.template .env
# =============================================================

# --- Django ---
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,host.docker.internal

# --- PostgreSQL ---
DATABASE_URL=postgres://openpg:openpgpwd@localhost:5432/roc_desk_db

# --- Redis / Celery ---
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# --- Evolution API (WhatsApp Gateway) ---
# Isi dengan URL di mana server API Anda berjalan.
# Jika project Django berjalan di mesin yang sama dengan mesin Docker Evolution API, Anda bisa pakai localhost.
# Tapi ingat, jika Django ada di dalam Docker juga, gunakan host.docker.internal:8080.
EVOLUTION_API_URL=http://localhost:8080

# Kunci API Global yang kita set di file docker-compose.yml 
# (Bagian: AUTHENTICATION_API_KEY)
EVOLUTION_API_KEY=rocdesk-evo-key-2026

# Nama instance yang baru saja berhasil kita buat dan yang akan Anda scan QR-nya
EVOLUTION_INSTANCE_NAME=helpdesk-wa-final

# --- Webhook Security ---
# Ini adalah token rahasia BEBAS buatan Anda sendiri. 
# Token ini HANYA digunakan agar jika ada orang luar menembak URL Webhook RoC Desk Anda,
# Django bisa tahu bahwa request itu benar-benar datang dari Evolution API Anda 
# (Evolution API akan mengirim token ini kembali via Webhook).
EVOLUTION_WEBHOOK_TOKEN=roc-secret-webhook-2026-xYz

# Email (Direct IMAP Polling for Gmail/Others)
# Generate an App Password if using Gmail (2-Step Verification)
IMAP_HOST=imap.gmail.com
IMAP_USER=joyodrono24@gmail.com
IMAP_APP_PASSWORD=zndzwsrugarpwzsh

# --- SMTP Email (Outbound) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=joyodrono24@gmail.com
EMAIL_HOST_PASSWORD=zndzwsrugarpwzsh
