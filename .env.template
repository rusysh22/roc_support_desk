# =============================================================
# RoC Desk — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in the values.
#   cp .env.template .env
# =============================================================

# --- Django ---
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,host.docker.internal

# -----------------------------------------------------------------
# Gateways Config
# -----------------------------------------------------------------
# WhatsApp (Evolution API)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_global_api_key_here
EVOLUTION_INSTANCE_NAME=ROC_SUPPORT
EVOLUTION_WEBHOOK_TOKEN=my_secure_webhook_token_123

# Email (Direct IMAP Polling for Gmail/Others)
# Generate an App Password if using Gmail (2-Step Verification)
IMAP_HOST=imap.gmail.com
IMAP_USER=your_email@gmail.com
IMAP_APP_PASSWORD=your_app_password_here

# SMTP (Outbound Email for Case Replies)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here

# --- PostgreSQL ---
DATABASE_URL=postgres://openpg:openpgpwd@localhost:5432/roc_desk_db

# --- Redis / Celery ---
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
